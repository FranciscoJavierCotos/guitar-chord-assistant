# ─── Required ──────────────────────────────────────────────────────────────────
# DeepSeek API key — spent on every LLM call. Keep it ONLY here / in the Render
# dashboard or a Render Secret File. Never commit it, log it, or return it.
DEEPSEEK_API_KEY=your_key_here

# Shared secret the Next.js server must send as the X-Internal-Token header.
# Generate a strong random value (e.g. `python -c "import secrets;print(secrets.token_urlsafe(32))"`).
# On Render this is generated automatically (generateValue) and shared to the frontend.
INTERNAL_API_TOKEN=generate_a_long_random_value

# ─── Optional ──────────────────────────────────────────────────────────────────
# development | production. In production: docs are disabled and CORS drops localhost.
ENV=development

# Port the server binds to. Render injects PORT automatically.
PORT=8000

# Allowed CORS origin (the production frontend URL). localhost is allowed only when ENV=development.
FRONTEND_URL=http://localhost:3000
