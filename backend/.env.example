# ─── Required ──────────────────────────────────────────────────────────────────
# DeepSeek API key — spent on every LLM call. Keep it ONLY here / in the Render
# dashboard or a Render Secret File. Never commit it, log it, or return it.
DEEPSEEK_API_KEY=your_key_here

# Shared secret the Next.js server must send as the X-Internal-Token header.
# Generate a strong random value (e.g. `python -c "import secrets;print(secrets.token_urlsafe(32))"`).
# On Render this is generated automatically (generateValue) and shared to the frontend.
INTERNAL_API_TOKEN=generate_a_long_random_value

# ─── Optional ──────────────────────────────────────────────────────────────────
# development | production. In production: docs are disabled and CORS drops localhost.
ENV=development

# Port the server binds to. Render injects PORT automatically.
PORT=8000

# Allowed CORS origin (the production frontend URL). localhost is allowed only when ENV=development.
FRONTEND_URL=http://localhost:3000

# ─── Supabase (Epic B — accounts & persistent practice history) ─────────────────
# The backend's durable data layer (Postgres + Auth + RLS). Optional for the
# data-less MVP paths: if unset, /api/health/db reports "unconfigured" and the app
# still runs. See backend/db.py and supabase/migrations/.
# Project URL, e.g. https://<ref>.supabase.co
# Also used by backend/auth.py (B1) to fetch the PUBLIC JWKS at
# <SUPABASE_URL>/auth/v1/.well-known/jwks.json for verifying user access tokens —
# so there is NO separate JWT signing secret to store. Use ASYMMETRIC signing keys
# in the Supabase project (Auth → JWT/Signing keys) so a public JWKS is available.
# SUPABASE_URL=
# Service-role key — SECRET, RLS-BYPASSING, backend-only. Never expose to the
# browser, never NEXT_PUBLIC_-prefix, never log/return it. (Supabase dashboard →
# Project Settings → API → service_role key.)
# SUPABASE_SERVICE_ROLE_KEY=
# Anon / publishable key — safe for the browser (RLS still applies). Used for
# per-user, RLS-enforced queries from B1 onward.
# SUPABASE_ANON_KEY=

# ─── Observability (optional; OpenTelemetry → Grafana Cloud free tier) ──────────
# Instrumentation is OPT-IN and a no-op unless OTEL_ENABLED=true AND an OTLP
# endpoint is set, so local dev / CI run without any of this. When on, the backend
# exports traces + metrics via OTLP/HTTP to Grafana Cloud (Tempo + Mimir).
# See observability/README.md for how to get the endpoint + Basic-auth header.
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-<zone>.grafana.net/otlp
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(instanceID:token)>
# OTEL_SERVICE_NAME=chordcoach-backend
# Optional cost-estimate tuning ($ per 1M tokens; defaults shown).
# DEEPSEEK_INPUT_COST_PER_MTOK=0.27
# DEEPSEEK_OUTPUT_COST_PER_MTOK=1.10

# ─── Gemini embeddings (Epic C — RAG corpus + retrieval) ────────────────────────
# Used by `python -m rag` (ingestion, story C0) and the retrieval tool (story C1) to
# embed text via gemini-embedding-001 (768-dim, truncated from 3072 via MRL). Get a
# key at https://aistudio.google.com/apikey. Optional for the rest of the app — only
# `python -m rag` and the (future) retrieval tool need it.
# GEMINI_API_KEY=

# ─── Eval harness (optional; only needed to run `python -m eval`) ────────────────
# The offline eval (backend/eval/) runs the golden set through the agent and an
# LLM-as-judge. The agent uses DEEPSEEK_API_KEY above. The judge is pinned and
# configurable; by default it reuses DEEPSEEK_API_KEY and the DeepSeek endpoint.
# EVAL_JUDGE_MODEL=deepseek-chat
# EVAL_JUDGE_BASE_URL=https://api.deepseek.com/v1
# EVAL_JUDGE_API_KEY=your_judge_key_here   # falls back to DEEPSEEK_API_KEY if unset
