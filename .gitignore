# ============================================================
# .gitignore — chord-coach (Guitar Progression Assistant)
# ============================================================

# Environment — NEVER commit secrets
**/.env
**/.env.local
**/.env.*.local
**/.env.production
**/.env.staging

# Python
backend/.venv/
backend/venv/
backend/__pycache__/
backend/**/__pycache__/
backend/**/*.pyc
backend/**/*.pyo
backend/.pytest_cache/
backend/*.egg-info/
backend/dist/
backend/build/
backend/.mypy_cache/
backend/.ruff_cache/

# Node / Next.js
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.pnp
frontend/.pnp.js
frontend/.yarn/install-state.gz
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/*.tsbuildinfo
frontend/next-env.d.ts
frontend/.vercel
frontend/coverage/

# OS / Editor
.DS_Store
Thumbs.db
*.pem
*.swp
*.swo
.vscode/
.idea/

# Claude Code — ignore personal settings, track project docs
.claude/
!.claude/CLAUDE.md

RENDER_MIGRATION.md
