# Server-only vars (NO NEXT_PUBLIC_ prefix) — these must never ship to the browser.
# The browser calls our own /api routes; those route handlers read these to reach
# the backend with the shared-secret header.

# Public URL of the FastAPI backend. On Render this is wired automatically from the
# backend service (fromService host). Locally, point at your running backend.
BACKEND_URL=http://localhost:8000

# Shared secret — MUST match the backend's INTERNAL_API_TOKEN. On Render it is
# pulled from the backend service via fromService so both sides share one value.
INTERNAL_API_TOKEN=generate_a_long_random_value

# ─── Supabase auth (Epic B; used from story B1 onward) ──────────────────────────
# These two are intentionally NEXT_PUBLIC_ (the browser runs Supabase Auth). The
# anon/publishable key is DESIGNED to be public — it is not a secret and is gated
# by Row-Level Security. This is the one allowed exception to the "no NEXT_PUBLIC_
# secrets" rule; the service-role key stays backend-only and must never appear here.
# NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
