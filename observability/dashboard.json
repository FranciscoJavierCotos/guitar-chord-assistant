{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus (Grafana Cloud / Mimir)",
      "description": "The Prometheus-compatible datasource your ChordCoach OTLP metrics land in.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "description": "ChordCoach backend observability: traffic, errors, latency percentiles, DeepSeek tokens/cost, tool usage, and rate-limit headroom. Metric names are the Prometheus form of the OTLP instruments emitted by backend/observability.py.",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["chordcoach", "observability"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "",
  "title": "ChordCoach — Backend Observability",
  "uid": "chordcoach-backend",
  "panels": [
    {
      "type": "row",
      "title": "Traffic & Errors (RED)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Agent request rate (turns/s)",
      "description": "Throughput of completed agent turns, split by streaming vs. non-streaming.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (streaming) (rate(chordcoach_agent_duration_seconds_count[5m]))",
          "legendFormat": "streaming={{streaming}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP error rate (5xx) per route",
      "description": "Server errors per route. Uses FastAPI auto-instrumentation; the metric/label names (http_route, http_response_status_code) depend on the opentelemetry-instrumentation version — adjust if your series differ.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (http_route) (rate(http_server_request_duration_seconds_count{http_response_status_code=~\"5..\"}[5m]))",
          "legendFormat": "{{http_route}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Rate-limit rejections (429/s)",
      "description": "slowapi rejections — per-IP burst limit or the global 500/day cap. A sustained line means traffic is hitting the cap.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (scope) (rate(chordcoach_ratelimit_rejections_total[5m]))",
          "legendFormat": "{{scope}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Latency",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "type": "timeseries",
      "title": "Agent latency p50 / p95 / p99",
      "description": "End-to-end agent turn latency from the chordcoach.agent.duration histogram.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(chordcoach_agent_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(chordcoach_agent_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(chordcoach_agent_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Streaming time-to-first-token p50 / p95",
      "description": "How long /api/chat/stream takes to emit its first answer token — the number the user actually feels.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(chordcoach_stream_ttft_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(chordcoach_stream_ttft_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "type": "row",
      "title": "Tokens & Cost",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
    },
    {
      "type": "timeseries",
      "title": "DeepSeek tokens/s (input vs output)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (kind) (rate(chordcoach_llm_tokens_total[5m]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Estimated DeepSeek cost ($/hour)",
      "description": "Estimated spend = token usage × configured list price (see DEEPSEEK_*_COST_PER_MTOK). An estimate for trend-watching, not a bill.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(chordcoach_llm_cost_usd_total[5m])) * 3600",
          "legendFormat": "$/hour",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Tool usage",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 }
    },
    {
      "type": "timeseries",
      "title": "Tool calls/s by tool",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (tool) (rate(chordcoach_tool_calls_total[5m]))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tool latency p95 by tool",
      "description": "Which tool is the latency hotspot. find_song_chords (web search) is usually the tallest.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le, tool) (rate(chordcoach_tool_duration_seconds_bucket[5m])))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ]
    }
  ]
}
