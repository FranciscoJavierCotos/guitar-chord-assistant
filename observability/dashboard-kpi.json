{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus (Grafana Cloud / Mimir)",
      "description": "The Prometheus-compatible datasource your ChordCoach OTLP metrics land in.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "description": "ChordCoach KPI overview: a single at-a-glance screen of headline numbers (turns, tokens, estimated cost, latency, error rate) plus a few trend charts. Tuned for the Grafana Cloud free tier — low-cardinality queries, no per-IP/per-session series. Companion to the deep-dive 'ChordCoach — Backend Observability' dashboard.",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["chordcoach", "observability", "kpi"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "",
  "title": "ChordCoach — KPI Overview",
  "uid": "chordcoach-kpi",
  "panels": [
    {
      "type": "row",
      "title": "Headline KPIs (selected time range)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Agent turns",
      "description": "Total completed agent turns over the selected time range.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(chordcoach_agent_duration_seconds_count[$__range]))",
          "instant": true,
          "legendFormat": "turns",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Tokens used",
      "description": "Total DeepSeek tokens (input + output) over the selected time range.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "purple" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(chordcoach_llm_tokens_total[$__range]))",
          "instant": true,
          "legendFormat": "tokens",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Estimated cost",
      "description": "Estimated DeepSeek spend over the selected range = token usage × configured list price (DEEPSEEK_*_COST_PER_MTOK). An estimate for trend-watching, not a bill.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": { "mode": "fixed", "fixedColor": "green" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(chordcoach_llm_cost_usd_total[$__range]))",
          "instant": true,
          "legendFormat": "cost",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Agent latency p95",
      "description": "95th-percentile end-to-end agent turn latency over the selected range.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 8 },
              { "color": "red", "value": 15 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(chordcoach_agent_duration_seconds_bucket[$__range])))",
          "instant": true,
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "TTFT p95",
      "description": "95th-percentile streaming time-to-first-token for /api/chat/stream — the responsiveness the user actually feels.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 6 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(chordcoach_stream_ttft_seconds_bucket[$__range])))",
          "instant": true,
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Tool error rate",
      "description": "Share of tool invocations that errored over the selected range. Uses the reliable chordcoach.tool.calls{status} counter rather than the version-dependent HTTP metric names.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.02 },
              { "color": "red", "value": 0.1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(chordcoach_tool_calls_total{status=\"error\"}[$__range])) / clamp_min(sum(increase(chordcoach_tool_calls_total[$__range])), 1)",
          "instant": true,
          "legendFormat": "error rate",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Trends",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 }
    },
    {
      "type": "timeseries",
      "title": "Request rate (turns/s)",
      "description": "Throughput of completed agent turns, split by streaming vs non-streaming.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (streaming) (rate(chordcoach_agent_duration_seconds_count[5m]))",
          "legendFormat": "streaming={{streaming}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Agent latency p50 / p95 / p99",
      "description": "End-to-end agent turn latency from the chordcoach.agent.duration histogram.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(chordcoach_agent_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(chordcoach_agent_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(chordcoach_agent_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "DeepSeek tokens/s (input vs output)",
      "description": "Token throughput by kind — the driver behind the cost estimate.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (kind) (rate(chordcoach_llm_tokens_total[5m]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tool calls/s by tool",
      "description": "Which tools the agent leans on. Low-cardinality (fixed tool name set).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (tool) (rate(chordcoach_tool_calls_total[5m]))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ]
    }
  ]
}
